<UserControl x:Class="SynthiaCode.App.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Integrated terminal">
    <Grid Background="{DynamicResource TerminalBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource TerminalBrush}"
                BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PowerShell"
                               Foreground="{DynamicResource TerminalInkBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Terminal.Status}"
                               Foreground="{DynamicResource TerminalMutedBrush}"
                               FontSize="11"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Terminal.WorkingDirectory}"
                               Foreground="{DynamicResource TerminalMutedBrush}"
                               FontSize="10"
                               Margin="12,0,0,0"
                               MaxWidth="520"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               ToolTip="{Binding Terminal.WorkingDirectory}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Start"
                            Command="{Binding Terminal.StartCommand}"
                            Style="{StaticResource CompactButton}"
                            Margin="0,0,4,0"
                            ToolTip="Start or restart an exited terminal session" />
                    <Button Content="Clear"
                            Command="{Binding Terminal.ClearCommand}"
                            Style="{StaticResource CompactButton}"
                            Margin="0,0,4,0" />
                    <Button Content="Stop"
                            Command="{Binding Terminal.KillCommand}"
                            Style="{StaticResource CompactButton}"
                            Margin="0,0,4,0" />
                    <Button Command="{Binding Terminal.ToggleMaximizeCommand}"
                            Margin="0,0,4,0"
                            AutomationProperties.Name="Maximize or restore terminal">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CompactButton}">
                                <Setter Property="Content" Value="Maximize" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Terminal.IsMaximized}" Value="True">
                                        <Setter Property="Content" Value="Restore" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Command="{Binding Terminal.ToggleCommand}"
                            Style="{StaticResource IconButton}"
                            AutomationProperties.Name="Close terminal"
                            ToolTip="Close terminal dock">
                        <Path Data="{StaticResource IconClose}"
                              Stroke="{DynamicResource TerminalInkBrush}"
                              StrokeThickness="1.3"
                              Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TextBox Grid.Row="1"
                 Text="{Binding Terminal.Output, Mode=OneWay}"
                 IsReadOnly="True"
                 FontFamily="{StaticResource MonoFont}"
                 FontSize="12"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 Padding="12,8"
                 Background="{DynamicResource TerminalBrush}"
                 Foreground="{DynamicResource TerminalInkBrush}"
                 CaretBrush="{DynamicResource TerminalInkBrush}"
                 SelectionBrush="{DynamicResource TerminalSelectionBrush}"
                 BorderThickness="0"
                 AutomationProperties.Name="Terminal output" />

        <Border Grid.Row="2"
                Background="{DynamicResource TerminalBrush}"
                BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="0,1,0,0"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Terminal.Input, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource MonoFont}"
                         Background="{DynamicResource SurfaceSunkenBrush}"
                         Foreground="{DynamicResource TerminalInkBrush}"
                         CaretBrush="{DynamicResource TerminalInkBrush}"
                         Padding="9,6"
                         AutomationProperties.Name="Terminal command input" />
                <Button Grid.Column="1"
                        Content="Send"
                        Command="{Binding Terminal.SendInputCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="76"
                        Margin="8,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
