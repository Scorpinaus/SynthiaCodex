<UserControl x:Class="SynthiaCode.App.Views.GitView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Margin="0,10,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Git.Branch}" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="{Binding Git.StatusMessage}" Foreground="{DynamicResource MutedInkBrush}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Editor" Command="{Binding Git.OpenEditorCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Explorer" Command="{Binding Git.RevealExplorerCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Refresh" Command="{Binding Git.RefreshCommand}" Style="{StaticResource CompactButton}"/></StackPanel></Grid>
        <Grid Grid.Row="1" Margin="0,14"><Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Changed files" Style="{StaticResource SectionLabel}"/><ListBox Grid.Row="1" ItemsSource="{Binding Git.ChangedFiles}" SelectedItem="{Binding Git.SelectedFile}" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True"><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="6"><TextBlock Text="{Binding DisplayPath}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding StatusSummary}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10"/></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox><StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0"><Button Content="Stage" Command="{Binding Git.StageCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Unstage" Command="{Binding Git.UnstageCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Discard" Command="{Binding Git.DiscardCommand}" Style="{StaticResource CompactButton}"/></StackPanel></Grid>
            <Grid Grid.Column="2"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Git.DiffViewLabel}" Style="{StaticResource SectionLabel}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Working" Command="{Binding Git.ShowWorkingDiffCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Staged" Command="{Binding Git.ShowStagedDiffCommand}" Style="{StaticResource CompactButton}"/></StackPanel></Grid><TextBox Grid.Row="1" Text="{Binding Git.SelectedDiff, Mode=OneWay}" IsReadOnly="True" FontFamily="{StaticResource MonoFont}" FontSize="12" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="10" Margin="0,8,0,0"/></Grid>
        </Grid>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Commit staged changes" Style="{StaticResource SectionLabel}"/><TextBox Text="{Binding Git.CommitMessage, UpdateSourceTrigger=PropertyChanged}" MinHeight="52" MaxHeight="90" AcceptsReturn="True" TextWrapping="Wrap" Padding="9"/></StackPanel><Button Grid.Column="1" Content="Commit" Command="{Binding Git.CommitCommand}" Style="{StaticResource PrimaryButton}" MinWidth="104" Margin="10,25,0,0" VerticalAlignment="Top"/></Grid>
        <Border Grid.RowSpan="3" Panel.ZIndex="10" Visibility="{Binding Git.IsRepository, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Background="{DynamicResource PanelBrush}"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460"><TextBlock Text="This folder is not a Git repository" FontSize="21" FontWeight="SemiBold" TextAlignment="Center"/><TextBlock Text="Choose a Git project to review changes, or continue using Task and Terminal." Foreground="{DynamicResource MutedInkBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,18"/><Button Content="Choose another project" Command="{Binding ProjectWorkspace.BrowseProjectCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center"/></StackPanel></Border>
    </Grid></Border>
</UserControl>
