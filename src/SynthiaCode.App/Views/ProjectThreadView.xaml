<UserControl x:Class="SynthiaCode.App.Views.ProjectThreadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:SynthiaCode.App.Views"
             AutomationProperties.Name="Chats and projects">
    <Border Background="{DynamicResource RailBrush}"
            BorderBrush="{DynamicResource LineBrush}"
            BorderThickness="0,0,1,0">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ChatSearchBox"
                         Text="{Binding ProjectWorkspace.ChatSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         ToolTip="Search all chats (Ctrl+K)"
                         AutomationProperties.Name="Search all chats"/>
                <Button Grid.Column="1"
                        Content="Clear"
                        Command="{Binding ProjectWorkspace.ClearChatSearchCommand}"
                        Style="{StaticResource CompactButton}"
                        Margin="6,0,0,0"
                        Visibility="{Binding ProjectWorkspace.HasChatSearch, Converter={StaticResource BooleanToVisibilityConverter}}"
                        AutomationProperties.Name="Clear chat search"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding ProjectWorkspace.ToggleChatsCommand}"
                        Style="{StaticResource CompactButton}"
                        HorizontalContentAlignment="Left"
                        Padding="4,2"
                        AutomationProperties.Name="Toggle Chats">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProjectWorkspace.ChatsChevron}" Width="18" Foreground="{DynamicResource MutedInkBrush}"/>
                        <TextBlock Text="Chats" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1"
                        Content="New"
                        Command="{Binding ProjectWorkspace.NewGeneralThreadCommand}"
                        Style="{StaticResource CreateThreadButton}"
                        ToolTip="New chat"
                        AutomationProperties.Name="New chat"/>
            </Grid>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding ProjectWorkspace.GeneralThreads}"
                     SelectedItem="{Binding ProjectWorkspace.SelectedGeneralThread, Mode=TwoWay}"
                     Visibility="{Binding ProjectWorkspace.IsChatsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                     MaxHeight="180"
                     Margin="0,0,0,12"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Pinned"
                                               Foreground="{DynamicResource SignalBrush}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Margin="0,0,6,0"
                                               Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </Grid>
                                <TextBlock Text="{Binding WorkspaceModeLabel}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Style="{StaticResource StatePill}"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"
                                    Visibility="{Binding HasActionableStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding ActivityLabel}" FontSize="10"/>
                            </Border>
                            <Button Grid.Column="2"
                                    Content="&#x22EF;"
                                    Style="{StaticResource ProjectActionButton}"
                                    Padding="7,2"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="Chat actions"
                                    AutomationProperties.Name="Chat actions"
                                    Tag="{Binding DataContext.ProjectWorkspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Click="OnThreadActionsClick">
                                <Button.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Resume" Command="{Binding ResumeThreadCommand}"/>
                                        <MenuItem Header="Fork" Command="{Binding ForkThreadCommand}"/>
                                        <MenuItem Header="{Binding PinActionLabel}" Command="{Binding TogglePinThreadCommand}"/>
                                        <Separator/>
                                        <MenuItem Header="Archive" Command="{Binding ArchiveThreadCommand}"/>
                                        <MenuItem Header="Unarchive" Command="{Binding UnarchiveThreadCommand}"/>
                                        <Separator/>
                                        <MenuItem Header="Delete" Command="{Binding DeleteThreadCommand}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding ProjectWorkspace.ToggleProjectsCommand}"
                        Style="{StaticResource CompactButton}"
                        HorizontalContentAlignment="Left"
                        Padding="4,2"
                        AutomationProperties.Name="Toggle Projects">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProjectWorkspace.ProjectsChevron}" Width="18" Foreground="{DynamicResource MutedInkBrush}"/>
                        <TextBlock Text="Projects" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1"
                        Content="Add"
                        Command="{Binding ProjectWorkspace.BrowseProjectCommand}"
                        Style="{StaticResource CompactButton}"
                        ToolTip="Add project (Ctrl+O)"
                        AutomationProperties.Name="Add project"/>
            </Grid>

            <ListBox Grid.Row="4"
                     ItemsSource="{Binding ProjectWorkspace.Projects}"
                     Visibility="{Binding ProjectWorkspace.IsProjectsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0,0,0,8"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding DataContext.ProjectWorkspace.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Path}"
                                        HorizontalContentAlignment="Stretch"
                                        BorderThickness="1"
                                        Padding="8,7"
                                        AutomationProperties.Name="{Binding Name, StringFormat=Project {0}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Chevron}" VerticalAlignment="Center" Foreground="{DynamicResource MutedInkBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding ThreadCount}" Foreground="{DynamicResource MutedInkBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding RunningSummary}" Foreground="{DynamicResource WarningBrush}" FontSize="9" HorizontalAlignment="Right"
                                                       Visibility="{Binding HasRunningThreads, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Grid.Column="1"
                                        Content="+"
                                        Command="{Binding DataContext.ProjectWorkspace.NewThreadForProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Path}"
                                        Style="{StaticResource CreateThreadButton}"
                                        Padding="9,5"
                                        Margin="6,0,0,0"
                                        ToolTip="New chat in current checkout"
                                        AutomationProperties.Name="{Binding Name, StringFormat=New chat in {0}}"/>
                                <Button Grid.Column="2"
                                        Content="&#x22EF;"
                                        Style="{StaticResource ProjectActionButton}"
                                        Padding="7,5"
                                        Margin="4,0,0,0"
                                        ToolTip="Project actions"
                                        AutomationProperties.Name="{Binding Name, StringFormat=Actions for project {0}}"
                                        Tag="{Binding DataContext.ProjectWorkspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Click="OnThreadActionsClick">
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="New chat in worktree"
                                                      Command="{Binding NewWorktreeThreadForProjectCommand}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.Path, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </Grid>

                            <StackPanel Margin="18,4,0,2"
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="No chats yet"
                                           Foreground="{DynamicResource MutedInkBrush}"
                                           FontSize="11"
                                           Margin="10,7"
                                           Visibility="{Binding HasThreads, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                <ListBox ItemsSource="{Binding Threads}"
                                         SelectedItem="{Binding DataContext.ProjectWorkspace.SelectedThread, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         HorizontalContentAlignment="Stretch"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="10,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Pinned"
                                                                   Foreground="{DynamicResource SignalBrush}"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,6,0"
                                                                   Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding WorkspaceModeLabel}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Style="{StaticResource StatePill}"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding HasActionableStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding ActivityLabel}" FontSize="10"/>
                                                </Border>
                                                <Button Grid.Column="2"
                                                        Content="⋯"
                                                        Style="{StaticResource ProjectActionButton}"
                                                        Padding="7,2"
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Chat actions"
                                                        AutomationProperties.Name="Chat actions"
                                                        Tag="{Binding DataContext.ProjectWorkspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Click="OnThreadActionsClick">
                                                    <Button.ContextMenu>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Header="Resume" Command="{Binding ResumeThreadCommand}"/>
                                                            <MenuItem Header="Fork" Command="{Binding ForkThreadCommand}"/>
                                                            <MenuItem Header="{Binding PinActionLabel}" Command="{Binding TogglePinThreadCommand}"/>
                                                            <Separator/>
                                                            <MenuItem Header="Archive" Command="{Binding ArchiveThreadCommand}"/>
                                                            <MenuItem Header="Unarchive" Command="{Binding UnarchiveThreadCommand}"/>
                                                            <MenuItem Header="Remove worktree" Command="{Binding RemoveWorktreeCommand}"/>
                                                            <Separator/>
                                                            <MenuItem Header="Delete" Command="{Binding DeleteThreadCommand}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="1"
                  Grid.RowSpan="4"
                  Background="{DynamicResource RailBrush}"
                  Panel.ZIndex="10"
                  Visibility="{Binding ProjectWorkspace.HasChatSearch, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding ProjectWorkspace.ChatSearchSummary}"
                           Foreground="{DynamicResource MutedInkBrush}"
                           FontSize="11"
                           Margin="4,0,4,6"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding ProjectWorkspace.ChatSearchResults}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         AutomationProperties.Name="Cross-chat search results">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ProjectWorkspace.OpenChatSearchResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CompactButton}"
                                    HorizontalContentAlignment="Stretch"
                                    Margin="0,0,0,4"
                                    Padding="8"
                                    AutomationProperties.Name="{Binding Title, StringFormat=Open chat {0}}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Pinned"
                                                   Foreground="{DynamicResource SignalBrush}"
                                                   FontSize="9"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,6,0"
                                                   Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </Grid>
                                    <TextBlock Text="{Binding ScopeLabel}"
                                               Foreground="{DynamicResource SignalBrush}"
                                               FontSize="10"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Snippet}"
                                               Foreground="{DynamicResource MutedInkBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               MaxHeight="48"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <views:UserAccountView Grid.Row="5" DataContext="{Binding Account}"/>
        </Grid>
    </Border>
</UserControl>
