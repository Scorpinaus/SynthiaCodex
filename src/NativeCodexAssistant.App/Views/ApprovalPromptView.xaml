<UserControl x:Class="NativeCodexAssistant.App.Views.ApprovalPromptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded"
             PreviewKeyDown="OnPreviewKeyDown"
             AutomationProperties.Name="Codex approval request">
    <Grid Background="#99000000">
        <Border Width="640"
                MaxWidth="760"
                MaxHeight="620"
                Margin="24"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Approval required" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Kind}"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource MutedInkBrush}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,18,0,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Reason}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="Requested action" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Border Padding="12"
                                Background="{DynamicResource CanvasBrush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Detail}"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding ApprovalQueue.ActivePrompt.PermissionOptions}"
                                      Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsGranted, Mode=TwoWay}"
                                              Margin="0,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Context}"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource MutedInkBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ApprovalQueue.ErrorMessage}"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ApprovalQueue.PendingCount, StringFormat={}{0} pending approval request(s)}"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource MutedInkBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </ScrollViewer>

                <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Command="{Binding ApprovalQueue.CancelCommand}"
                            Style="{StaticResource CompactButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Decline"
                            Command="{Binding ApprovalQueue.DeclineCommand}"
                            Style="{StaticResource CompactButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Allow for session"
                            Command="{Binding ApprovalQueue.AllowSessionCommand}"
                            Style="{StaticResource CompactButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Allow once"
                            Command="{Binding ApprovalQueue.AllowOnceCommand}"
                            Style="{StaticResource CompactButton}"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
