<UserControl x:Class="NativeCodexAssistant.App.Views.ProjectThreadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource RailBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="120"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="Projects" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Add" Command="{Binding ProjectWorkspace.BrowseProjectCommand}" Style="{StaticResource CompactButton}" ToolTip="Add project (Ctrl+O)"/>
            </Grid>
            <TextBlock Grid.Row="1" Text="Recent projects" Foreground="{DynamicResource MutedInkBrush}" FontSize="11" Margin="0,2,0,6"/>
            <ListBox Grid.Row="2" ItemsSource="{Binding ProjectWorkspace.RecentProjects}" BorderThickness="0" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                <ListBox.ItemTemplate><DataTemplate>
                    <Button Command="{Binding DataContext.ProjectWorkspace.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Path}" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="8,5">
                        <StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Path}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/></StackPanel>
                    </Button>
                </DataTemplate></ListBox.ItemTemplate>
            </ListBox>
            <Grid Grid.Row="3" Margin="0,14,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="Threads" Style="{StaticResource SectionLabel}"/><TextBlock Grid.Column="1" Text="{Binding ProjectWorkspace.Threads.Count}" Foreground="{DynamicResource MutedInkBrush}"/>
            </Grid>
            <ListBox Grid.Row="4" ItemsSource="{Binding ProjectWorkspace.Threads}" SelectedItem="{Binding ProjectWorkspace.SelectedThread}" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                <ListBox.ItemTemplate><DataTemplate>
                    <Grid Margin="8,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding WorkspaceModeLabel}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10"/></StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource StatePill}" VerticalAlignment="Center"><TextBlock Text="{Binding TurnStatus}" FontSize="10"/></Border>
                    </Grid>
                </DataTemplate></ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Row="5" Style="{StaticResource Card}" Padding="10" Margin="0,10,0,0">
                <StackPanel><TextBlock Text="New thread workspace" Style="{StaticResource SectionLabel}"/>
                    <ComboBox ItemsSource="{Binding ProjectWorkspace.WorkspaceModeOptions}" SelectedItem="{Binding ProjectWorkspace.NewThreadWorkspaceMode}" Margin="0,6,0,8"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Button Content="New thread" Command="{Binding ProjectWorkspace.NewThreadCommand}" Style="{StaticResource CreateThreadButton}"/>
                        <Button Grid.Column="1" Content="More" Command="{Binding ProjectWorkspace.ResumeThreadCommand}" Style="{StaticResource CompactButton}" Margin="8,0,0,0" ToolTip="Resume selected thread"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
