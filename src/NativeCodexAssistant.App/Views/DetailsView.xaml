<UserControl x:Class="NativeCodexAssistant.App.Views.DetailsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1,0,0,0"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Details" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Account, runtime, and diagnostics" Foreground="{DynamicResource MutedInkBrush}" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="Close" Command="{Binding ToggleDetailsPaneCommand}" Style="{StaticResource CompactButton}"/></Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel>
            <Border Style="{StaticResource Card}" Margin="0,0,0,10"><StackPanel><TextBlock Text="Codex" FontWeight="SemiBold"/><TextBlock Text="{Binding DiagnosticsViewModel.CodexSummary}" Foreground="{DynamicResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/><TextBlock Text="{Binding DiagnosticsViewModel.CodexExecutablePath}" Style="{StaticResource ValueText}"/><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Content="Refresh" Command="{Binding DiagnosticsViewModel.RefreshCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Run doctor" Command="{Binding DiagnosticsViewModel.RunDoctorCommand}" Style="{StaticResource CompactButton}"/></StackPanel></StackPanel></Border>
            <Border Style="{StaticResource Card}" Margin="0,0,0,10"><StackPanel><TextBlock Text="Account" FontWeight="SemiBold"/><TextBlock Text="{Binding DiagnosticsViewModel.AuthSummary}" Foreground="{DynamicResource MutedInkBrush}" Margin="0,4,0,4"/><TextBlock Text="{Binding DiagnosticsViewModel.AuthDetail}" TextWrapping="Wrap"/><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Content="ChatGPT" Command="{Binding DiagnosticsViewModel.SignInChatGptCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Device code" Command="{Binding DiagnosticsViewModel.SignInDeviceCodeCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/><Button Content="Sign out" Command="{Binding DiagnosticsViewModel.SignOutCommand}" Style="{StaticResource CompactButton}"/></StackPanel></StackPanel></Border>
            <Expander Header="Runtime information" IsExpanded="True" Margin="0,0,0,8"><StackPanel Margin="0,8,0,0"><TextBlock Text="{Binding DiagnosticsViewModel.CodexHome, StringFormat=Codex home: {0}}" Style="{StaticResource ValueText}" Margin="0,0,0,8"/><ListBox ItemsSource="{Binding DiagnosticsViewModel.Lines}" MaxHeight="360" BorderThickness="0" Background="Transparent" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True"><ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="0,0,0,7"/></DataTemplate></ListBox.ItemTemplate></ListBox></StackPanel></Expander>
            <Expander Header="Raw protocol events" IsExpanded="False"><ListBox ItemsSource="{Binding TaskWorkspace.RawEvents}" MaxHeight="360" Margin="0,8,0,0" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True"><ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="4,5"/></DataTemplate></ListBox.ItemTemplate></ListBox></Expander>
        </StackPanel></ScrollViewer>
    </Grid></Border>
</UserControl>
