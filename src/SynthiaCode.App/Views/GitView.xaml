<UserControl x:Class="SynthiaCode.App.Views.GitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Changed files inspector">
    <Grid Background="{DynamicResource InspectorBrush}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Git.Branch, TargetNullValue=Changes}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Git.StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       Margin="0,3,0,0"
                       TextWrapping="Wrap" />
            <WrapPanel Margin="0,10,0,0">
                <Button Content="Editor"
                        Command="{Binding Git.OpenEditorCommand}"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,5,5" />
                <Button Content="Explorer"
                        Command="{Binding Git.RevealExplorerCommand}"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,5,5" />
                <Button Content="Refresh"
                        Command="{Binding Git.RefreshCommand}"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,5,5" />
            </WrapPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="120" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Changed files" Style="{StaticResource SectionLabel}" />
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Git.ChangedFiles}"
                     SelectedItem="{Binding Git.SelectedFile}"
                     BorderThickness="1"
                     ItemContainerStyle="{StaticResource NavigationRow}"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     AutomationProperties.Name="Changed files">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DisplayPath}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding DisplayPath}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding StatusSummary}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="10"
                                       Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <WrapPanel Grid.Row="2" Margin="0,7,0,0">
                <Button Content="Stage"
                        Command="{Binding Git.StageCommand}"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,5,0" />
                <Button Content="Unstage"
                        Command="{Binding Git.UnstageCommand}"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,5,0" />
                <Button Content="Discard"
                        Command="{Binding Git.DiscardCommand}"
                        Style="{StaticResource DangerButton}" />
            </WrapPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Git.DiffViewLabel}"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Working"
                        Command="{Binding Git.ShowWorkingDiffCommand}"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,5,0" />
                <Button Content="Staged"
                        Command="{Binding Git.ShowStagedDiffCommand}"
                        Style="{StaticResource CompactButton}" />
            </StackPanel>
        </Grid>

        <TextBox Grid.Row="3"
                 Text="{Binding Git.SelectedDiff, Mode=OneWay}"
                 IsReadOnly="True"
                 FontFamily="{StaticResource MonoFont}"
                 FontSize="11"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 Padding="9"
                 Background="{DynamicResource SurfaceSunkenBrush}"
                 AutomationProperties.Name="Selected file diff" />

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Commit staged changes" Style="{StaticResource SectionLabel}" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Git.CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="42"
                         MaxHeight="76"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         AutomationProperties.Name="Commit message" />
                <Button Grid.Column="1"
                        Content="Commit"
                        Command="{Binding Git.CommitCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="84"
                        Margin="8,0,0,0"
                        VerticalAlignment="Top" />
            </Grid>
        </Grid>

        <Border Grid.RowSpan="5"
                Panel.ZIndex="10"
                Style="{StaticResource EmptyStatePresenter}"
                Visibility="{Binding Git.IsRepository, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" MaxWidth="280">
                <TextBlock Text="No Git project attached"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center" />
                <TextBlock Text="Choose a Git project to review changes, or continue with a General task."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,16" />
                <Button Content="Choose a project"
                        Command="{Binding ProjectWorkspace.BrowseProjectCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
