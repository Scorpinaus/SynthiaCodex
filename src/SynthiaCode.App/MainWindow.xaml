<Window x:Class="SynthiaCode.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SynthiaCode.App.Views"
        mc:Ignorable="d" Title="SynthiaCode" Closing="OnClosing" SizeChanged="OnSizeChanged" PreviewKeyDown="OnPreviewKeyDown"
        Icon="/SynthiaCode.App;component/Assets/Branding/SynthiaCode.ico"
        MinHeight="640" MinWidth="800" Height="800" Width="1320">
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding ProjectWorkspace.BrowseProjectCommand}"/>
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding TaskWorkspace.ComposerSendCommand}"/>
        <KeyBinding Key="Enter" Modifiers="Control+Shift" Command="{Binding TaskWorkspace.AlternateFollowUpCommand}"/>
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding ToggleProjectRailCommand}"/>
        <KeyBinding Key="D" Modifiers="Control+Shift" Command="{Binding ToggleDetailsPaneCommand}"/>
        <KeyBinding Key="T" Modifiers="Control+Shift" Command="{Binding Terminal.ToggleCommand}"/>
        <KeyBinding Key="F5" Command="{Binding DiagnosticsViewModel.RefreshCommand}"/>
    </Window.InputBindings>
    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto" MinHeight="64"/><RowDefinition Height="*"/><RowDefinition Height="Auto" MinHeight="30"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"><Grid Margin="14,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding ToggleProjectRailCommand}" Style="{StaticResource HeaderButton}" Content="☰" ToolTip="Toggle chats and projects (Ctrl+B)"/>
            <Border Grid.Column="1"
                    Width="38"
                    Height="38"
                    Margin="12,0,0,0"
                    Padding="3"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Image x:Name="AppLogoImage"
                       Source="/SynthiaCode.App;component/Assets/Branding/SynthiaCodeLogo.png"
                       Stretch="Uniform"
                       IsHitTestVisible="False"
                       AutomationProperties.Name="SynthiaCode logo"/>
            </Border>
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0"><TextBlock Text="SynthiaCode" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="{Binding ProjectWorkspace.SelectedProjectPath, TargetNullValue=Choose a project to start working}" Foreground="{DynamicResource MutedInkBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/></StackPanel>
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource StatePill}" Margin="0,0,8,0" ToolTip="Codex app-server connection status"><StackPanel Orientation="Horizontal"><Ellipse Width="7" Height="7" Margin="0,0,6,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{DynamicResource MutedInkBrush}"/><Style.Triggers><DataTrigger Binding="{Binding TaskWorkspace.AppServerHealth}" Value="Codex connected"><Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/></DataTrigger><DataTrigger Binding="{Binding TaskWorkspace.AppServerHealth}" Value="Codex connecting"><Setter Property="Fill" Value="{DynamicResource WarningBrush}"/></DataTrigger><DataTrigger Binding="{Binding TaskWorkspace.AppServerHealth}" Value="Codex reconnecting"><Setter Property="Fill" Value="{DynamicResource WarningBrush}"/></DataTrigger><DataTrigger Binding="{Binding TaskWorkspace.AppServerHealth}" Value="Codex unavailable"><Setter Property="Fill" Value="{DynamicResource DangerBrush}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse><TextBlock Text="{Binding TaskWorkspace.AppServerHealth}" FontSize="11" VerticalAlignment="Center"/></StackPanel></Border>
                <Button Content="Terminal" Command="{Binding Terminal.ToggleCommand}" Style="{StaticResource HeaderButton}" ToolTip="Open or hide Terminal (Ctrl+Shift+T)"/>
                <Button Content="Settings" Command="{Binding OpenSettingsCommand}" Style="{StaticResource HeaderButton}" ToolTip="Open settings and diagnostics (Ctrl+Shift+D)"/>
                <Button Content="Exit" Command="{Binding ExitApplicationCommand}" Style="{StaticResource HeaderButton}"/>
            </StackPanel>
        </Grid></Border>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="{Binding IsProjectRailOpen, Converter={StaticResource BooleanToGridLengthConverter}, ConverterParameter=268}"/><ColumnDefinition Width="*"/><ColumnDefinition Width="{Binding IsDetailsPaneOpen, Converter={StaticResource BooleanToGridLengthConverter}, ConverterParameter=340}"/></Grid.ColumnDefinitions>
            <views:ProjectThreadView x:Name="NavigationFeature" Grid.Column="0" Visibility="{Binding IsProjectRailOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Grid Grid.Column="1" Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Margin="2,0,2,12"
                           Text="{Binding ProjectWorkspace.SelectedThreadTitle}"
                           FontSize="21"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedWorkspaceTabIndex}">
                    <TabItem Header="Task"><views:TaskView x:Name="TaskFeature"/></TabItem>
                    <TabItem Header="Terminal" Visibility="{Binding Terminal.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><views:TerminalView/></TabItem>
                    <TabItem Header="Changes"><views:GitView/></TabItem>
                </TabControl>
            </Grid>
            <views:DetailsView Grid.Column="2" Visibility="{Binding IsDetailsPaneOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBrush}"><Grid Margin="12,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="11"/><TextBlock Grid.Column="1" Text="Ctrl+O project  ·  Ctrl+Enter run  ·  Ctrl+B navigation  ·  Ctrl+Shift+D settings" VerticalAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" FontSize="10"/></Grid></Border>
        <views:ApprovalPromptView Grid.RowSpan="3"
                                  Panel.ZIndex="100"
                                  Visibility="{Binding ApprovalQueue.HasPendingApproval, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</Window>
