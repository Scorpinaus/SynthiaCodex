<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <sys:Double x:Key="Space2">2</sys:Double>
    <sys:Double x:Key="Space4">4</sys:Double>
    <sys:Double x:Key="Space8">8</sys:Double>
    <sys:Double x:Key="Space12">12</sys:Double>
    <sys:Double x:Key="Space16">16</sys:Double>
    <sys:Double x:Key="Space20">20</sys:Double>
    <sys:Double x:Key="Space24">24</sys:Double>
    <sys:Double x:Key="Space32">32</sys:Double>

    <CornerRadius x:Key="Radius4">4</CornerRadius>
    <CornerRadius x:Key="Radius8">8</CornerRadius>
    <CornerRadius x:Key="Radius10">10</CornerRadius>
    <CornerRadius x:Key="Radius12">12</CornerRadius>

    <sys:Double x:Key="ControlHeightCompact">28</sys:Double>
    <sys:Double x:Key="ControlHeightStandard">32</sys:Double>
    <sys:Double x:Key="ControlHeightEmphasized">36</sys:Double>
    <sys:Double x:Key="ControlHeightTouch">44</sys:Double>
    <sys:Double x:Key="ProjectRailWidth">276</sys:Double>
    <sys:Double x:Key="InspectorWidth">340</sys:Double>
    <sys:Double x:Key="ReadableTranscriptWidth">900</sys:Double>

    <Duration x:Key="MotionFast">0:0:0.08</Duration>
    <Duration x:Key="MotionStandard">0:0:0.14</Duration>
    <Duration x:Key="MotionDeliberate">0:0:0.2</Duration>
    <CubicEase x:Key="MotionEaseOut" EasingMode="EaseOut" />

    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource AppCanvasBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="Card" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius8}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="StatePill" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <Style x:Key="ConversationTurnCard" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="4,8" />
    </Style>

    <Style x:Key="ConversationMessageSurface" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius10}" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="ConversationUserSurface"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource ConversationMessageSurface}">
        <Setter Property="Background" Value="{DynamicResource ConversationUserBrush}" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="MaxWidth" Value="760" />
    </Style>

    <Style x:Key="ConversationAssistantSurface"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource ConversationMessageSurface}">
        <Setter Property="Background" Value="{DynamicResource ConversationAssistantBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
</ResourceDictionary>
