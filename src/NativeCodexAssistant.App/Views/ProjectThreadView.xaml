<UserControl x:Class="NativeCodexAssistant.App.Views.ProjectThreadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:NativeCodexAssistant.App.Views"
             AutomationProperties.Name="Projects and threads">
    <Border Background="{DynamicResource RailBrush}"
            BorderBrush="{DynamicResource LineBrush}"
            BorderThickness="0,0,1,0">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Projects" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Add"
                        Command="{Binding ProjectWorkspace.BrowseProjectCommand}"
                        Style="{StaticResource CompactButton}"
                        ToolTip="Add project (Ctrl+O)"
                        AutomationProperties.Name="Add project"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding ProjectWorkspace.Projects}"
                     Margin="0,0,0,8"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding DataContext.ProjectWorkspace.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Path}"
                                        HorizontalContentAlignment="Stretch"
                                        BorderThickness="1"
                                        Padding="8,7"
                                        AutomationProperties.Name="{Binding Name, StringFormat=Project {0}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Chevron}" VerticalAlignment="Center" Foreground="{DynamicResource MutedInkBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding ThreadCount}" Foreground="{DynamicResource MutedInkBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding RunningSummary}" Foreground="{DynamicResource WarningBrush}" FontSize="9" HorizontalAlignment="Right"
                                                       Visibility="{Binding HasRunningThreads, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Grid.Column="1"
                                        Content="+"
                                        Command="{Binding DataContext.ProjectWorkspace.NewThreadForProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Path}"
                                        Style="{StaticResource CreateThreadButton}"
                                        Padding="9,5"
                                        Margin="6,0,0,0"
                                        ToolTip="New thread in current checkout"
                                        AutomationProperties.Name="{Binding Name, StringFormat=New thread in {0}}"/>
                                <Button Grid.Column="2"
                                        Content="&#x22EF;"
                                        Style="{StaticResource ProjectActionButton}"
                                        Padding="7,5"
                                        Margin="4,0,0,0"
                                        ToolTip="Project actions"
                                        AutomationProperties.Name="{Binding Name, StringFormat=Actions for project {0}}"
                                        Tag="{Binding DataContext.ProjectWorkspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Click="OnThreadActionsClick">
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="New thread in worktree"
                                                      Command="{Binding NewWorktreeThreadForProjectCommand}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.Path, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </Grid>

                            <StackPanel Margin="18,4,0,2"
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="No threads yet"
                                           Foreground="{DynamicResource MutedInkBrush}"
                                           FontSize="11"
                                           Margin="10,7"
                                           Visibility="{Binding HasThreads, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                <ListBox ItemsSource="{Binding Threads}"
                                         SelectedItem="{Binding DataContext.ProjectWorkspace.SelectedThread, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         HorizontalContentAlignment="Stretch"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="10,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding WorkspaceModeLabel}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Style="{StaticResource StatePill}"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding HasActionableStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding ActivityLabel}" FontSize="10"/>
                                                </Border>
                                                <Button Grid.Column="2"
                                                        Content="⋯"
                                                        Style="{StaticResource ProjectActionButton}"
                                                        Padding="7,2"
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Thread actions"
                                                        AutomationProperties.Name="Thread actions"
                                                        Tag="{Binding DataContext.ProjectWorkspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Click="OnThreadActionsClick">
                                                    <Button.ContextMenu>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Header="Resume" Command="{Binding ResumeThreadCommand}"/>
                                                            <MenuItem Header="Fork" Command="{Binding ForkThreadCommand}"/>
                                                            <Separator/>
                                                            <MenuItem Header="Archive" Command="{Binding ArchiveThreadCommand}"/>
                                                            <MenuItem Header="Unarchive" Command="{Binding UnarchiveThreadCommand}"/>
                                                            <MenuItem Header="Remove worktree" Command="{Binding RemoveWorktreeCommand}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <views:UserAccountView Grid.Row="2" DataContext="{Binding Account}"/>
        </Grid>
    </Border>
</UserControl>
