<UserControl x:Class="NativeCodexAssistant.App.Views.TaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource Card}" AutomationProperties.Name="Task transcript">
            <Grid>
            <TextBlock Text="Start a conversation by describing a task below." Foreground="{DynamicResource MutedInkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding TaskWorkspace.HasConversation, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
            <ListBox x:Name="ConversationList" ItemsSource="{Binding TaskWorkspace.ConversationTurns}" BorderThickness="0" Background="Transparent" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True" ScrollViewer.ScrollChanged="OnConversationScrollChanged" AutomationProperties.Name="Multi-turn conversation">
                <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/><Setter Property="Background" Value="Transparent"/><Setter Property="IsTabStop" Value="False"/></Style></ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate><DataTemplate>
                    <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="4,4,4,18" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="You" Style="{StaticResource SectionLabel}" Foreground="{DynamicResource SignalBrush}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="{Binding StartedAt, StringFormat={}{0:g}}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/><Border Style="{StaticResource StatePill}"><TextBlock Text="{Binding StatusLabel}" FontSize="10"/></Border></StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding UserPrompt}" TextWrapping="Wrap" FontSize="14" LineHeight="21" Margin="0,6,0,10"/>
                            <Expander Header="{Binding ActivitySummary}" IsExpanded="{Binding IsActivityExpanded, Mode=TwoWay}" Margin="0,2,0,10" AutomationProperties.Name="Turn activity">
                                <ItemsControl ItemsSource="{Binding Activity}" Margin="8,5,0,0"><ItemsControl.ItemTemplate><DataTemplate>
                                    <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,7"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Ellipse Width="7" Height="7" Fill="{DynamicResource SignalBrush}" VerticalAlignment="Top" Margin="0,5,0,0"/><StackPanel Grid.Column="2"><TextBlock Text="{Binding Title}" FontWeight="SemiBold"/><TextBlock Text="{Binding Detail}" Foreground="{DynamicResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/></StackPanel><TextBlock Grid.Column="3" Text="{Binding Kind}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" Margin="8,2,0,0"/>
                                    </Grid></Border>
                                </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                            </Expander>
                            <TextBlock Text="Assistant" Style="{StaticResource SectionLabel}" Foreground="{DynamicResource CreateActionBrush}"/>
                            <TextBlock Text="{Binding AssistantResponseDisplay}" TextWrapping="Wrap" FontSize="14" LineHeight="22" Margin="0,6,0,0" AutomationProperties.LiveSetting="Polite"/>
                        </StackPanel>
                    </Border>
                </DataTemplate></ListBox.ItemTemplate>
            </ListBox>
            <Button x:Name="JumpLatestButton" Content="Jump to latest" Style="{StaticResource CompactButton}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,14" Visibility="Collapsed" Click="OnJumpLatestClick"/>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="12"><StackPanel>
            <Expander Header="Run settings" IsExpanded="False" Margin="0,0,0,8"><Grid Margin="0,8,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Model" Style="{StaticResource SectionLabel}"/><DockPanel><Button DockPanel.Dock="Right" Content="Load models" Command="{Binding TaskWorkspace.LoadModelsCommand}" Margin="8,0,0,0" Style="{StaticResource CompactButton}"/><ComboBox ItemsSource="{Binding TaskWorkspace.ModelOptions}" Text="{Binding TaskWorkspace.ModelOverride, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"/></DockPanel></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Reasoning" Style="{StaticResource SectionLabel}"/><ComboBox ItemsSource="{Binding TaskWorkspace.ReasoningEffortOptions}" SelectedItem="{Binding TaskWorkspace.ReasoningEffortOverride, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
            </Grid></Expander>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Grid>
                    <TextBox x:Name="PromptBox" Text="{Binding TaskWorkspace.Prompt, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="82" MaxHeight="150" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="10" Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}" ToolTip="Describe a task. Press Ctrl+Enter to run."/>
                    <TextBox x:Name="GuidanceBox" Text="{Binding TaskWorkspace.SteeringText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="82" MaxHeight="150" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="10" Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Guide the active task using this same composer."/>
                </Grid>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Button Content="{Binding TaskWorkspace.ComposerActionLabel}" Command="{Binding TaskWorkspace.SubmitCommand}" Style="{StaticResource RunTaskButton}" MinWidth="104" Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    <Button Content="Guide task" Command="{Binding TaskWorkspace.SteerCommand}" Style="{StaticResource RunTaskButton}" MinWidth="104" Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="Cancel" Command="{Binding TaskWorkspace.CancelCommand}" MinWidth="104" Margin="0,8,0,0" Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </StackPanel></Border>
    </Grid>
</UserControl>
