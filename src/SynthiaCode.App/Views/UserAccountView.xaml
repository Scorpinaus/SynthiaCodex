<UserControl x:Class="SynthiaCode.App.Views.UserAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded"
             PreviewKeyDown="OnPreviewKeyDown"
             Unloaded="OnUnloaded"
             AutomationProperties.Name="Codex account">
    <UserControl.Resources>
        <Style x:Key="AccountToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SubtleBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource SignalBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource SignalBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UsageProgressStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="{DynamicResource SignalBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="AccountFooter"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,8,0,0">
            <ToggleButton x:Name="AccountToggle"
                          Style="{StaticResource AccountToggleStyle}"
                          IsChecked="{Binding IsFlyoutOpen, Mode=TwoWay}"
                          ToolTip="Open account and usage"
                          AutomationProperties.Name="Open account and usage">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="32"
                            Height="32"
                            CornerRadius="16"
                            Background="{DynamicResource SignalBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Initials}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="7,0,6,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding IdentityDetail}"
                                   Foreground="{DynamicResource MutedInkBrush}"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="&#x2303;"
                               Foreground="{DynamicResource MutedInkBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </ToggleButton>
        </Border>

        <Popup x:Name="AccountPopup"
               PlacementTarget="{Binding ElementName=AccountToggle}"
               Placement="Top"
               VerticalOffset="-4"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="False"
               IsOpen="{Binding PlacementTarget.DataContext.IsFlyoutOpen, RelativeSource={RelativeSource Self}, Mode=TwoWay}"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <Border Width="252"
                    MaxHeight="520"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="34"
                                Height="34"
                                CornerRadius="17"
                                Background="{DynamicResource SignalBrush}">
                            <TextBlock Text="{Binding Initials}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding IdentityDetail}"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding UsageStatus}" FontWeight="SemiBold"/>
                        <Button Grid.Column="1"
                                Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource CompactButton}"
                                MinHeight="24"
                                Padding="7,2"
                                AutomationProperties.Name="Refresh account usage"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="270"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding UsageBuckets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,11">
                                            <TextBlock Text="{Binding BucketLabel}"
                                                       Foreground="{DynamicResource MutedInkBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,3"
                                                       Visibility="{Binding HasBucketLabel, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" FontSize="11"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding RemainingLabel}"
                                                           Foreground="{DynamicResource MutedInkBrush}"
                                                           FontSize="11"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding RemainingPercent}" Style="{StaticResource UsageProgressStyle}"/>
                                            <TextBlock Text="{Binding ResetLabel}"
                                                       Foreground="{DynamicResource MutedInkBrush}"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding CreditsLabel}"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="10"
                                       Margin="0,0,0,6"
                                       Visibility="{Binding HasCredits, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding ResetCreditsLabel}"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="10"
                                       Margin="0,0,0,6"
                                       Visibility="{Binding HasResetCredits, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Margin="0,8,0,0">
                        <Separator Margin="0,0,0,7"/>
                        <Button Content="Settings"
                                Command="{Binding OpenSettingsCommand}"
                                HorizontalContentAlignment="Left"
                                AutomationProperties.Name="Open settings"/>
                        <Button Content="Sign in"
                                Command="{Binding SignInCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="0,5,0,0"
                                Visibility="{Binding IsSignedIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <Button Content="Sign out"
                                Command="{Binding SignOutCommand}"
                                HorizontalContentAlignment="Left"
                                Margin="0,5,0,0"
                                Visibility="{Binding IsSignedIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
