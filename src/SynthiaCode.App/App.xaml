<Application x:Class="SynthiaCode.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:SynthiaCode.App.Services"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/LightTheme.xaml" />
                <ResourceDictionary Source="Themes/Foundations.xaml" />
                <ResourceDictionary Source="Themes/Typography.xaml" />
                <ResourceDictionary Source="Themes/Icons.xaml" />
                <ResourceDictionary Source="Themes/Controls.Buttons.xaml" />
                <ResourceDictionary Source="Themes/Controls.Inputs.xaml" />
                <ResourceDictionary Source="Themes/Controls.Navigation.xaml" />
                <ResourceDictionary Source="Themes/Controls.Transient.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <services:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <services:BooleanToGridLengthConverter x:Key="BooleanToGridLengthConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
