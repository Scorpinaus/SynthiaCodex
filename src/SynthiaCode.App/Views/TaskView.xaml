<UserControl x:Class="SynthiaCode.App.Views.TaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SynthiaCode.App.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Style="{StaticResource PaneSurface}"
                Padding="8"
                AutomationProperties.Name="Conversation transcript">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="2,0,2,8">
                <Button Content="Find"
                        Command="{Binding TaskWorkspace.OpenFindInChatCommand}"
                        Style="{StaticResource CompactButton}"
                        HorizontalAlignment="Right"
                        ToolTip="Find in chat (Ctrl+F)"
                        Visibility="{Binding TaskWorkspace.IsFindInChatOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        AutomationProperties.Name="Find in chat"/>
                <Border Background="{DynamicResource FieldBrush}"
                        BorderBrush="{DynamicResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6"
                        Visibility="{Binding TaskWorkspace.IsFindInChatOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FindInChatBox"
                                 Text="{Binding TaskWorkspace.FindInChatText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="180"
                                 Padding="6,4"
                                 PreviewKeyDown="OnFindInChatPreviewKeyDown"
                                 AutomationProperties.Name="Find text in current chat"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TaskWorkspace.FindInChatSummary}"
                                   Foreground="{DynamicResource MutedInkBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                        <Button Grid.Column="2"
                                Content="Previous"
                                Command="{Binding TaskWorkspace.FindPreviousCommand}"
                                Style="{StaticResource CompactButton}"
                                Margin="0,0,4,0"
                                AutomationProperties.Name="Previous chat match"/>
                        <Button Grid.Column="3"
                                Content="Next"
                                Command="{Binding TaskWorkspace.FindNextCommand}"
                                Style="{StaticResource CompactButton}"
                                Margin="0,0,4,0"
                                AutomationProperties.Name="Next chat match"/>
                        <Button Grid.Column="4"
                                Content="Close"
                                Command="{Binding TaskWorkspace.CloseFindInChatCommand}"
                                Style="{StaticResource CompactButton}"
                                AutomationProperties.Name="Close find in chat"/>
                    </Grid>
                </Border>
            </Grid>
            <Border Grid.Row="1"
                    Style="{StaticResource EmptyStatePresenter}"
                    MaxWidth="520"
                    Visibility="{Binding TaskWorkspace.HasConversation, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="What would you like to build?"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Describe a task below. SynthiaCode will keep the conversation, activity, approvals, and workspace context together."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,7,0,0"/>
                </StackPanel>
            </Border>
            <ListBox x:Name="ConversationList"
                     Grid.Row="1"
                     ItemsSource="{Binding TaskWorkspace.ConversationTurns}"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="2"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.ScrollChanged="OnConversationScrollChanged"
                     AutomationProperties.Name="Multi-turn conversation">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="IsTabStop" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="2,2,2,18" AutomationProperties.Name="Conversation turn">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ConversationTurnCard}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFindMatch}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCurrentFindMatch}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SignalBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Border Style="{StaticResource ConversationUserSurface}" Margin="48,0,0,12" AutomationProperties.Name="User message">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="You" Style="{StaticResource ConversationRoleText}" Foreground="{DynamicResource SignalBrush}"/>
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource StatePill}"
                                                    Visibility="{Binding IsSuperseded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Previous version" FontSize="10"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding UserPrompt}"
                                                   Style="{StaticResource ConversationBodyText}"
                                                   Visibility="{Binding IsPromptEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                        <Border BorderBrush="{DynamicResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="8"
                                                Visibility="{Binding IsPromptEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBox Text="{Binding EditedPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="72"
                                                         VerticalScrollBarVisibility="Auto"
                                                         AutomationProperties.Name="Edit user prompt"/>
                                                <TextBlock Text="Resubmitting rewinds conversation context; workspace file changes are kept."
                                                           Style="{StaticResource ConversationMetadataText}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                    <Button Content="Cancel"
                                                            Command="{Binding DataContext.TaskWorkspace.CancelPromptEditCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource CompactButton}"
                                                            Margin="0,0,6,0"
                                                            AutomationProperties.Name="Cancel prompt edit"/>
                                                    <Button Content="Resubmit"
                                                            Command="{Binding DataContext.TaskWorkspace.SubmitPromptEditCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding CanSubmitPromptEdit}"
                                                            Style="{StaticResource CompactButton}"
                                                            AutomationProperties.Name="Resubmit edited prompt"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding UserAttachments}"
                                                      Margin="0,8,0,0"
                                                      Visibility="{Binding HasUserAttachments, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="5" Margin="0,0,8,8" Padding="6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image Source="{Binding ManagedPath}" Width="108" Height="80" Stretch="Uniform" ToolTip="{Binding DisplayName}" Visibility="{Binding IsImage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            <TextBlock Text="{Binding KindLabel}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0" Visibility="{Binding IsImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding StartedAtLocalTime, StringFormat={}{0:g}}"
                                                       Style="{StaticResource ConversationMetadataText}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       AutomationProperties.Name="User message date and time"/>
                                            <Button Grid.Column="2"
                                                    Content="Edit"
                                                    Command="{Binding DataContext.TaskWorkspace.BeginPromptEditCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanEditPrompt, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Style="{StaticResource CompactButton}"
                                                    MinHeight="24"
                                                    Padding="7,2"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Edit and resubmit this prompt"
                                                    AutomationProperties.Name="Edit user prompt"/>
                                            <Button Grid.Column="3"
                                                    Content="Copy"
                                                    CommandParameter="{Binding UserPrompt}"
                                                    Style="{StaticResource CompactButton}"
                                                    MinHeight="24"
                                                    Padding="7,2"
                                                    Click="OnCopyMessageClick"
                                                    ToolTip="Copy user message"
                                                    AutomationProperties.Name="Copy user message"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ConversationAssistantSurface}" Margin="0,0,48,0" AutomationProperties.Name="Assistant message">
                                    <StackPanel>
                                        <Border BorderBrush="{DynamicResource LineBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,0,0,10"
                                                Margin="0,0,0,10"
                                                Visibility="{Binding HasActivity, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                AutomationProperties.Name="Turn activities">
                                            <Expander Header="{Binding ActivitySummary}" IsExpanded="{Binding IsActivityExpanded, Mode=TwoWay}" AutomationProperties.Name="Turn activity">
                                                <ItemsControl ItemsSource="{Binding Activity}" Margin="8,5,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,7">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                                    <Ellipse Width="7" Height="7" Fill="{DynamicResource SignalBrush}" VerticalAlignment="Top" Margin="0,5,0,0"/>
                                                                    <StackPanel Grid.Column="2"><TextBlock Text="{Binding Title}" Style="{StaticResource ConversationActivityTitleText}" TextWrapping="Wrap"/><TextBlock Text="{Binding Detail}" Style="{StaticResource ConversationActivityDetailText}" Margin="0,2,0,0"/></StackPanel>
                                                                    <TextBlock Grid.Column="3" Text="{Binding CategoryLabel}" Style="{StaticResource ConversationMetadataText}" Margin="8,2,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </Border>
                                        <TextBlock Text="Assistant" Style="{StaticResource ConversationRoleText}" Foreground="{DynamicResource CreateActionBrush}" Margin="0,0,0,6"/>
                                        <controls:MarkdownTextBlock Markdown="{Binding AssistantResponseDisplay}"
                                                                    LinkCommand="{Binding DataContext.TaskWorkspace.OpenExternalUriCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                    Style="{StaticResource ConversationBodyText}"
                                                                    AutomationProperties.LiveSetting="Polite"/>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CompletedAtLocalTime, StringFormat={}{0:g}}"
                                                       Style="{StaticResource ConversationMetadataText}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       AutomationProperties.Name="Assistant message date and time"/>
                                            <Button Grid.Column="2"
                                                    Content="Copy"
                                                    CommandParameter="{Binding AssistantResponse}"
                                                    IsEnabled="{Binding HasAssistantResponse}"
                                                    Style="{StaticResource CompactButton}"
                                                    MinHeight="24"
                                                    Padding="7,2"
                                                    Click="OnCopyMessageClick"
                                                    ToolTip="Copy assistant message"
                                                    AutomationProperties.Name="Copy assistant message"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button x:Name="JumpLatestButton" Grid.Row="1" Content="Jump to latest" Style="{StaticResource CompactButton}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,14" Visibility="Collapsed" Click="OnJumpLatestClick"/>
            </Grid>
        </Border>
        <Border x:Name="QueuedFollowUpPanel"
                Grid.Row="1"
                Style="{StaticResource Card}"
                Margin="0,10,0,0"
                Padding="10"
                Visibility="{Binding TaskWorkspace.HasQueuedFollowUps, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                AutomationProperties.Name="Queued follow-ups">
            <StackPanel>
                <TextBlock Text="{Binding TaskWorkspace.QueuedFollowUps.Count, StringFormat=Queued follow-ups ({0})}"
                           FontWeight="SemiBold"
                           Margin="2,0,2,6"/>
                <ScrollViewer MaxHeight="230" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="QueuedFollowUpList"
                                  ItemsSource="{Binding TaskWorkspace.QueuedFollowUps}"
                                  AutomationProperties.Name="Queued follow-up messages">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource FieldBrush}"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        Margin="0,0,0,6">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding Text}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="48"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                            <TextBox Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True"
                                                     MinHeight="56"
                                                     MaxHeight="120"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     AutomationProperties.Name="Edit queued follow-up"/>
                                        </Grid>
                                        <TextBlock Text="{Binding LastError}"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,5,0,0"
                                                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                   AutomationProperties.LiveSetting="Polite"/>
                                        <Grid Margin="0,7,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding StateLabel}"
                                                       Foreground="{DynamicResource MutedInkBrush}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <WrapPanel Grid.Column="1">
                                                <Button Content="Edit"
                                                        Command="{Binding DataContext.TaskWorkspace.BeginQueuedFollowUpEditCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CompactButton}"
                                                        MinHeight="32"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                        AutomationProperties.Name="Edit queued follow-up"/>
                                                <Button Content="Save"
                                                        Command="{Binding DataContext.TaskWorkspace.SaveQueuedFollowUpEditCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CompactButton}"
                                                        MinHeight="32"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        AutomationProperties.Name="Save queued follow-up"/>
                                                <Button Content="Cancel edit"
                                                        Command="{Binding DataContext.TaskWorkspace.CancelQueuedFollowUpEditCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CompactButton}"
                                                        MinHeight="32"
                                                        Margin="4,0,0,0"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <Button Content="Up"
                                                        Command="{Binding DataContext.TaskWorkspace.MoveQueuedFollowUpUpCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CompactButton}"
                                                        MinHeight="32"
                                                        Margin="4,0,0,0"
                                                        ToolTip="Move earlier"/>
                                                <Button Content="Down"
                                                        Command="{Binding DataContext.TaskWorkspace.MoveQueuedFollowUpDownCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CompactButton}"
                                                        MinHeight="32"
                                                        Margin="4,0,0,0"
                                                        ToolTip="Move later"/>
                                                <Button Content="Send now"
                                                        Command="{Binding DataContext.TaskWorkspace.SendQueuedFollowUpCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CompactButton}"
                                                        MinHeight="32"
                                                        Margin="4,0,0,0"/>
                                                <Button Content="Delete"
                                                        Command="{Binding DataContext.TaskWorkspace.DeleteQueuedFollowUpCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource CompactButton}"
                                                        MinHeight="32"
                                                        Margin="4,0,0,0"/>
                                            </WrapPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Border x:Name="ComposerDropTarget"
                Grid.Row="2"
                Style="{StaticResource PaneSurface}"
                Margin="0,12,0,0"
                Padding="12"
                AllowDrop="True"
                AutomationProperties.Name="Message composer">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid x:Name="PromptInputPanel" Grid.Row="1">
                    <TextBox x:Name="PromptBox"
                             Text="{Binding TaskWorkspace.Prompt, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             MinHeight="82"
                             MaxHeight="150"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             PreviewKeyDown="OnComposerPreviewKeyDown"
                             Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                             ToolTip="Describe a task. Press Ctrl+Enter to run."
                             AutomationProperties.Name="Task prompt"/>
                    <TextBox x:Name="GuidanceBox"
                             Text="{Binding TaskWorkspace.SteeringText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             MinHeight="82"
                             MaxHeight="150"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             PreviewKeyDown="OnComposerPreviewKeyDown"
                             Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                             ToolTip="Guide the active task using this same composer."
                             AutomationProperties.Name="Active task guidance"/>
                </Grid>

                <StackPanel x:Name="AttachmentPreviewPanel"
                            Grid.Row="0"
                            Margin="0,0,0,8"
                            Visibility="{Binding TaskWorkspace.HasAttachments, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="AttachmentPreviewList"
                                      ItemsSource="{Binding TaskWorkspace.Attachments}"
                                      AutomationProperties.Name="Attachment previews">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="152" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,8,0" Padding="5">
                                        <StackPanel>
                                            <Image Source="{Binding ManagedPath}" Height="72" Stretch="Uniform" ToolTip="{Binding DisplayName}" Visibility="{Binding IsImage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <Border Height="72" Background="{DynamicResource PanelBrush}" CornerRadius="4" Visibility="{Binding IsImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding KindLabel}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding WorkspaceRelativePath}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="136"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" Margin="2,4,2,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding LocationLabel}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" Margin="2,1,2,0"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                                <Button Content="Open" Click="OnOpenAttachmentClick" Style="{StaticResource CompactButton}" Padding="5" ToolTip="Open file or reveal folder"/>
                                                <Button Content="←" Command="{Binding DataContext.TaskWorkspace.MoveAttachmentLeftCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" CommandParameter="{Binding}" Style="{StaticResource CompactButton}" MinWidth="30" Padding="4" ToolTip="Move image left"/>
                                                <Button Content="→" Command="{Binding DataContext.TaskWorkspace.MoveAttachmentRightCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" CommandParameter="{Binding}" Style="{StaticResource CompactButton}" MinWidth="30" Padding="4" Margin="3,0,0,0" ToolTip="Move image right"/>
                                                <Button Content="Remove" Command="{Binding DataContext.TaskWorkspace.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" CommandParameter="{Binding}" Style="{StaticResource CompactButton}" Padding="5" Margin="3,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Text="{Binding TaskWorkspace.AttachmentValidationMessage}"
                               Foreground="{DynamicResource DangerBrush}"
                               Margin="2,5,0,0"
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite"/>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel x:Name="ComposerOptionsPanel" VerticalAlignment="Center">
                    <Button x:Name="ModelOptionsButton"
                            Command="{Binding TaskWorkspace.OpenOptionsCommand}"
                            Style="{StaticResource CompactButton}"
                            MinHeight="32"
                            MaxWidth="340"
                            Padding="10,4"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            IsEnabled="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            ToolTip="Choose the model, reasoning effort, and Fast mode for the next turn."
                            AutomationProperties.Name="Model, reasoning, and Fast options">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding TaskWorkspace.ModelSelectionSummary}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="⌄" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                        <ComboBox x:Name="ExecutionPolicySelector"
                                  ItemsSource="{Binding ExecutionPolicy.ModeOptions}"
                                  SelectedItem="{Binding ExecutionPolicy.SelectedMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding CanChangeExecutionPolicy}"
                                  MinHeight="32"
                                  MinWidth="132"
                                  MaxWidth="180"
                                  Margin="8,0,0,0"
                                  VerticalContentAlignment="Center"
                                  AutomationProperties.Name="Execution policy">
                            <ComboBox.ToolTip>
                                <StackPanel MaxWidth="320">
                                    <TextBlock Text="{Binding ExecutionPolicy.EffectiveSummary}"/>
                                    <TextBlock Text="{Binding ExecutionPolicy.ManagedSummary}"
                                               Foreground="{DynamicResource MutedInkBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ExecutionPolicy.ConfigurationWarning}"
                                               Foreground="{DynamicResource DangerBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <ComboBox x:Name="CustomPermissionProfileSelector"
                                  ItemsSource="{Binding ExecutionPolicy.CustomProfileOptions}"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding ExecutionPolicy.SelectedCustomProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding CanChangeExecutionPolicy}"
                                  Visibility="{Binding ExecutionPolicy.IsCustom, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  MinHeight="32"
                                  MinWidth="150"
                                  MaxWidth="220"
                                  Margin="8,0,0,0"
                                  VerticalContentAlignment="Center"
                                  ToolTip="Choose the config.toml default or a named permission profile."
                                  AutomationProperties.Name="Custom permission profile">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ComboBoxItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAllowed}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.55"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Description}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button x:Name="AttachButton"
                                Click="OnAttachClick"
                                Style="{StaticResource IconButton}"
                                MinHeight="32"
                                MinWidth="36"
                                Margin="8,0,0,0"
                                Padding="8,4"
                                ToolTip="Attach images, files, or folders. Outside files and folders are saved as managed snapshots."
                                AutomationProperties.Name="Attach">
                            <Path Data="{StaticResource IconAttach}"
                                  Stroke="{DynamicResource TextPrimaryBrush}"
                                  StrokeThickness="1.4"
                                  Stretch="Uniform"/>
                            <Button.ContextMenu>
                                <ContextMenu Placement="Top">
                                    <MenuItem Header="Images..."
                                              Click="OnAttachImagesClick"
                                              AutomationProperties.Name="Attach images"/>
                                    <MenuItem Header="Files..."
                                              Click="OnAttachFilesClick"
                                              AutomationProperties.Name="Attach files"/>
                                    <MenuItem Header="Folder..."
                                              Click="OnAttachFolderClick"
                                              AutomationProperties.Name="Attach folder"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </WrapPanel>

                    <Popup x:Name="ModelOptionsPopup"
                           PlacementTarget="{Binding ElementName=ModelOptionsButton}"
                           Placement="Top"
                           VerticalOffset="-8"
                           IsOpen="{Binding TaskWorkspace.IsOptionsFlyoutOpen, Mode=TwoWay}"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           DataContext="{Binding DataContext, ElementName=ModelOptionsButton}">
                        <Border Width="380"
                                MaxHeight="460"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource ButtonBorderBrush}"
                                BorderThickness="1"
                                PreviewKeyDown="OnModelOptionsPreviewKeyDown">
                            <Grid>
                                <StackPanel Visibility="{Binding TaskWorkspace.IsOptionsMainPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="4,2,4,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Model options" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TaskWorkspace.AccountPlanLabel}"
                                                   Foreground="{DynamicResource MutedInkBrush}"
                                                   Visibility="{Binding TaskWorkspace.HasAccountPlanLabel, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                   AutomationProperties.Name="Account plan context"/>
                                    </Grid>

                                    <Button Command="{Binding TaskWorkspace.ShowModelsCommand}"
                                            Margin="0,2"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Stretch"
                                            AutomationProperties.Name="Choose model">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Model" Foreground="{DynamicResource MutedInkBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TaskWorkspace.SelectedModel.DisplayName, TargetNullValue=Load models}" TextTrimming="CharacterEllipsis"/>
                                            <Path Grid.Column="2"
                                                  Data="{StaticResource IconChevronRight}"
                                                  Width="6"
                                                  Height="10"
                                                  Margin="8,0,0,0"
                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                  StrokeThickness="1.5"
                                                  Stretch="Uniform"/>
                                        </Grid>
                                    </Button>

                                    <Button Command="{Binding TaskWorkspace.ShowReasoningCommand}"
                                            Margin="0,2"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Stretch"
                                            AutomationProperties.Name="Choose reasoning effort">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Reasoning" Foreground="{DynamicResource MutedInkBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TaskWorkspace.SelectedReasoning.DisplayName, TargetNullValue=Default}"/>
                                            <Path Grid.Column="2"
                                                  Data="{StaticResource IconChevronRight}"
                                                  Width="6"
                                                  Height="10"
                                                  Margin="8,0,0,0"
                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                  StrokeThickness="1.5"
                                                  Stretch="Uniform"/>
                                        </Grid>
                                    </Button>

                                    <Border Margin="0,8,0,4" Padding="10,8" Background="{DynamicResource FieldBrush}" CornerRadius="5">
                                        <StackPanel>
                                            <CheckBox Content="Fast mode"
                                                      IsChecked="{Binding TaskWorkspace.IsFastModeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding TaskWorkspace.IsFastModeAvailable}"
                                                      AutomationProperties.Name="Fast mode"/>
                                            <TextBlock Text="{Binding TaskWorkspace.FastModeDescription}"
                                                       Foreground="{DynamicResource MutedInkBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Loading the model catalog..."
                                               Margin="4,8,4,2"
                                               Foreground="{DynamicResource MutedInkBrush}"
                                               Visibility="{Binding TaskWorkspace.IsModelCatalogLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding TaskWorkspace.ModelCatalogError}"
                                               Margin="4,8,4,2"
                                               Foreground="{DynamicResource DangerBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding TaskWorkspace.HasModelCatalogError, Converter={StaticResource BooleanToVisibilityConverter}}"
                                               AutomationProperties.LiveSetting="Polite"/>
                                    <Button Content="Refresh models"
                                            Command="{Binding TaskWorkspace.LoadModelsCommand}"
                                            Style="{StaticResource CompactButton}"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,0"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding TaskWorkspace.IsOptionsModelPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button Content="Back to model options"
                                            Command="{Binding TaskWorkspace.ShowOptionsMainCommand}"
                                            Style="{StaticResource CompactButton}"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,8"/>
                                    <ListBox ItemsSource="{Binding TaskWorkspace.ModelCatalog}"
                                             SelectedItem="{Binding TaskWorkspace.SelectedModel, Mode=TwoWay}"
                                             MaxHeight="360"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             AutomationProperties.Name="Available models">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="8,4"
                                                            MaxHeight="44"
                                                            ToolTip="{Binding AvailabilityMessage}">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource MutedInkBrush}"
                                                               FontSize="11"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Description}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                                <StackPanel Visibility="{Binding TaskWorkspace.IsOptionsReasoningPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button Content="Back to model options"
                                            Command="{Binding TaskWorkspace.ShowOptionsMainCommand}"
                                            Style="{StaticResource CompactButton}"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TaskWorkspace.SelectedModel.DisplayName}"
                                               Foreground="{DynamicResource MutedInkBrush}"
                                               Margin="8,0,8,6"/>
                                    <ListBox ItemsSource="{Binding TaskWorkspace.ReasoningOptions}"
                                             SelectedItem="{Binding TaskWorkspace.SelectedReasoning, Mode=TwoWay}"
                                             MaxHeight="330"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             AutomationProperties.Name="Supported reasoning efforts">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="8,6">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource MutedInkBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Popup>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                        <Border x:Name="ContextWindowIndicator"
                                Style="{StaticResource StatePill}"
                                MinHeight="32"
                                MinWidth="46"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                ToolTip="{Binding TaskWorkspace.ContextWindowToolTip}"
                                ToolTipService.InitialShowDelay="250"
                                ToolTipService.ShowDuration="60000"
                                AutomationProperties.Name="Context window usage"
                                AutomationProperties.HelpText="{Binding TaskWorkspace.ContextWindowToolTip}">
                            <TextBlock Text="{Binding TaskWorkspace.ContextWindowIndicator}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Button Content="{Binding TaskWorkspace.ComposerActionLabel}"
                                Command="{Binding TaskWorkspace.SubmitCommand}"
                                Style="{StaticResource RunTaskButton}"
                                MinWidth="104"
                                Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <Button Content="{Binding TaskWorkspace.ComposerActionLabel}"
                                Command="{Binding TaskWorkspace.SteerCommand}"
                                Style="{StaticResource RunTaskButton}"
                                MinWidth="104"
                                Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Button x:Name="AlternateFollowUpButton"
                                Content="{Binding TaskWorkspace.AlternateFollowUpActionLabel}"
                                Command="{Binding TaskWorkspace.AlternateFollowUpCommand}"
                                Style="{StaticResource CompactButton}"
                                MinHeight="32"
                                MinWidth="118"
                                Margin="8,0,0,0"
                                Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                                ToolTip="Use the other follow-up behavior once (Ctrl+Shift+Enter)."
                                AutomationProperties.Name="Use alternate follow-up behavior"/>
                        <Button Content="Cancel"
                                Command="{Binding TaskWorkspace.CancelCommand}"
                                MinWidth="104"
                                Margin="8,0,0,0"
                                Visibility="{Binding TaskWorkspace.IsTurnRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
