<Window x:Class="NativeCodexAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Native Codex Assistant"
        Closing="OnClosing"
        MinHeight="680"
        MinWidth="1100"
        Height="760"
        Width="1240">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Native Codex Assistant" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedProjectPath, TargetNullValue=Select a project to begin}" Foreground="{DynamicResource MutedInkBrush}" FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme, UpdateSourceTrigger=PropertyChanged}"
                              Width="92"
                              Margin="0,0,8,0"
                              ToolTip="Application theme" />
                    <Button Content="Refresh" Command="{Binding RefreshDiagnosticsCommand}" Margin="0,0,8,0" />
                    <Button Content="Terminal" Command="{Binding ToggleTerminalCommand}" Margin="0,0,8,0" ToolTip="Show or hide the integrated terminal tab" />
                    <Button Content="Sign in" Command="{Binding SignInChatGptCommand}" Style="{StaticResource PrimaryButton}" />
                    <Button Content="Exit" Command="{Binding ExitApplicationCommand}" Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource RailBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="150" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Projects" Style="{StaticResource SectionLabel}" />
                    <Button Grid.Row="1" Content="Add project" Command="{Binding BrowseProjectCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,16" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding RecentProjects}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Path}"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        Margin="0,0,0,8"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Path}" Foreground="{DynamicResource MutedInkBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="3" Text="Threads" Style="{StaticResource SectionLabel}" Margin="0,14,0,8" />
                    <ListBox Grid.Row="4"
                             ItemsSource="{Binding ProjectThreads}"
                             SelectedItem="{Binding SelectedThread}"
                             BorderBrush="{DynamicResource LineBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6">
                                    <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ThreadId}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding WorkspaceModeLabel}" Foreground="{DynamicResource MutedInkBrush}" FontSize="10" />
                                    <TextBlock Text="{Binding ActivityLabel}" Foreground="{DynamicResource CopperBrush}" FontSize="10" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="5" Margin="0,10,0,0">
                        <TextBlock Text="New thread workspace" Style="{StaticResource SectionLabel}" />
                        <ComboBox ItemsSource="{Binding WorkspaceModeOptions}"
                                  SelectedItem="{Binding NewThreadWorkspaceMode}"
                                  Margin="0,0,0,8" />
                        <WrapPanel>
                            <Button Content="New" Command="{Binding NewThreadCommand}" Margin="0,0,6,6" />
                            <Button Content="Resume" Command="{Binding ResumeThreadCommand}" Margin="0,0,6,6" />
                            <Button Content="Fork" Command="{Binding ForkThreadCommand}" Margin="0,0,6,6" />
                            <Button Content="Archive" Command="{Binding ArchiveThreadCommand}" Margin="0,0,6,6" />
                            <Button Content="Unarchive" Command="{Binding UnarchiveThreadCommand}" Margin="0,0,6,6" />
                            <Button Content="Remove worktree" Command="{Binding RemoveWorktreeCommand}" Margin="0,0,0,6" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource CopperBrush}" CornerRadius="3" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding SelectedProjectName}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource MutedInkBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Row="1" Margin="0,18">
                    <TabItem Header="Task">
                <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Thread surface" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding SelectedProjectName}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ActiveWorkspaceLabel, StringFormat=Workspace: {0}}" Foreground="{DynamicResource CopperBrush}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding ActiveWorkspacePath}" Foreground="{DynamicResource MutedInkBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding AuthSummary}" Foreground="{DynamicResource MutedInkBrush}" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding AppServerHealth, StringFormat=App-server: {0}}" Foreground="{DynamicResource MutedInkBrush}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,22,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.35*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Timeline" Style="{StaticResource SectionLabel}" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding TimelineItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Kind}" Foreground="{DynamicResource MutedInkBrush}" FontSize="11" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding Method}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource MutedInkBrush}" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Final response" Style="{StaticResource SectionLabel}" />
                                <Border Grid.Row="1" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding FinalResponse}" TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Model" Style="{StaticResource SectionLabel}" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Load" Command="{Binding LoadModelsCommand}" Margin="8,0,0,0" MinWidth="64" />
                                    <ComboBox ItemsSource="{Binding ModelOptions}"
                                              Text="{Binding ModelOverride, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              MinHeight="30" />
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Reasoning" Style="{StaticResource SectionLabel}" />
                                <ComboBox ItemsSource="{Binding ReasoningEffortOptions}"
                                          SelectedItem="{Binding ReasoningEffortOverride, UpdateSourceTrigger=PropertyChanged}"
                                          MinHeight="30" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     MinHeight="86"
                                     MaxHeight="150"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="10" />
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <Button Content="Run" Command="{Binding SubmitPromptCommand}" Style="{StaticResource PrimaryButton}" MinWidth="96" Margin="0,0,0,8" />
                                <Button Content="Cancel" Command="{Binding CancelTurnCommand}" MinWidth="96" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="4" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SteeringText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="34"
                                     Padding="8"
                                     ToolTip="Send additional guidance to the active turn" />
                            <Button Grid.Column="1"
                                    Content="Steer active turn"
                                    Command="{Binding SteerTurnCommand}"
                                    Margin="10,0,0,0" />
                        </Grid>
                    </Grid>
                </Border>
                    </TabItem>

                    <TabItem Header="Terminal"
                             Visibility="{Binding IsTerminalVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="PowerShell terminal" Style="{StaticResource SectionLabel}" />
                                        <TextBlock Text="{Binding TerminalWorkingDirectory}" FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding TerminalStatus, StringFormat=Status: {0}}" Foreground="{DynamicResource MutedInkBrush}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Start PowerShell" Command="{Binding StartTerminalCommand}" Margin="0,0,8,0" />
                                        <Button Content="Clear" Command="{Binding ClearTerminalCommand}" Margin="0,0,8,0" />
                                        <Button Content="Kill" Command="{Binding KillTerminalCommand}" />
                                    </StackPanel>
                                </Grid>

                                <TextBox Grid.Row="1"
                                         Text="{Binding TerminalOutput, Mode=OneWay}"
                                         IsReadOnly="True"
                                         FontFamily="{StaticResource MonoFont}"
                                         FontSize="12"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         HorizontalScrollBarVisibility="Auto"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="10"
                                         Margin="0,14,0,12"
                                         ToolTip="Select text and press Ctrl+C to copy" />

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding TerminalInput, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="{StaticResource MonoFont}"
                                             Padding="9"
                                             ToolTip="Paste or type a PowerShell command" />
                                    <Button Grid.Column="1"
                                            Content="Send"
                                            Command="{Binding SendTerminalInputCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            MinWidth="88"
                                            Margin="10,0,0,0" />
                                </Grid>
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem Header="Changes">
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Git workspace" Style="{StaticResource SectionLabel}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding GitBranch}" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="  /  " Foreground="{DynamicResource MutedInkBrush}" />
                                            <TextBlock Text="{Binding GitStatusMessage}" Foreground="{DynamicResource MutedInkBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Open editor" Command="{Binding OpenInEditorCommand}" Margin="0,0,8,0" ToolTip="Open the selected file or project in the configured editor" />
                                        <Button Content="Explorer" Command="{Binding RevealInExplorerCommand}" Margin="0,0,8,0" ToolTip="Reveal the selected file in Explorer" />
                                        <Button Content="Refresh" Command="{Binding RefreshGitCommand}" ToolTip="Refresh repository status" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Changed files" Style="{StaticResource SectionLabel}" />
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding ChangedFiles}"
                                                 SelectedItem="{Binding SelectedGitFile}"
                                                 BorderBrush="{DynamicResource LineBrush}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayPath}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding StatusSummary}" Foreground="{DynamicResource MutedInkBrush}" FontSize="11" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding StatusCode}" FontFamily="{StaticResource MonoFont}" Foreground="{DynamicResource CopperBrush}" Margin="8,0,0,0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                            <Button Content="Stage" Command="{Binding StageSelectedFileCommand}" Margin="0,0,8,8" />
                                            <Button Content="Unstage" Command="{Binding UnstageSelectedFileCommand}" Margin="0,0,8,8" />
                                            <Button Content="Discard" Command="{Binding RevertSelectedFileCommand}" Margin="0,0,0,8" ToolTip="Discard changes after confirmation" />
                                        </WrapPanel>
                                    </Grid>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DiffViewLabel}" Style="{StaticResource SectionLabel}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Working" Command="{Binding ShowWorkingDiffCommand}" Margin="0,0,8,6" MinHeight="26" Padding="9,2" />
                                                <Button Content="Staged" Command="{Binding ShowStagedDiffCommand}" Margin="0,0,0,6" MinHeight="26" Padding="9,2" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBox Grid.Row="1"
                                                 Text="{Binding SelectedDiff, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 FontFamily="{StaticResource MonoFont}"
                                                 FontSize="12"
                                                 AcceptsReturn="True"
                                                 AcceptsTab="True"
                                                 TextWrapping="NoWrap"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Padding="10" />
                                    </Grid>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Commit message" Style="{StaticResource SectionLabel}" />
                                        <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="58"
                                                 MaxHeight="96"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Padding="9" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Commit staged"
                                            Command="{Binding CommitCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            MinWidth="118"
                                            Margin="12,25,0,0"
                                            VerticalAlignment="Top" />
                                </Grid>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>

            <Border Grid.Column="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <TextBlock Text="Diagnostics" Style="{StaticResource SectionLabel}" />
                        <Button Content="Run Codex doctor"
                                Command="{Binding RunCodexDoctorCommand}"
                                Margin="0,0,0,14" />

                        <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Codex" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CodexSummary}" Foreground="{DynamicResource MutedInkBrush}" Margin="0,4,0,10" />
                                <TextBlock Text="{Binding CodexExecutablePath}" Style="{StaticResource ValueText}" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Sign-in" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AuthSummary}" Foreground="{DynamicResource MutedInkBrush}" Margin="0,4,0,8" />
                                <TextBlock Text="{Binding AuthDetail}" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="ChatGPT" Command="{Binding SignInChatGptCommand}" Margin="0,0,8,0" />
                                    <Button Content="Device code" Command="{Binding SignInDeviceCodeCommand}" Margin="0,0,8,0" />
                                    <Button Content="Sign out" Command="{Binding SignOutCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Codex home" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CodexHome}" Style="{StaticResource ValueText}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Runtime" Style="{StaticResource SectionLabel}" Margin="0,4,0,8" />
                        <ItemsControl ItemsSource="{Binding Diagnostics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="0,0,0,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Raw events" Style="{StaticResource SectionLabel}" Margin="0,14,0,8" />
                        <ItemsControl ItemsSource="{Binding RawEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="0,0,0,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource StatusBarBrush}">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" VerticalAlignment="Center" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding SettingsPath}" Foreground="#C9D4CE" VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</Window>
