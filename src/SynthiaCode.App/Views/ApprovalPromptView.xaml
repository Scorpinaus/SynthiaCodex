<UserControl x:Class="SynthiaCode.App.Views.ApprovalPromptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded"
             PreviewKeyDown="OnPreviewKeyDown"
             AutomationProperties.Name="Codex approval request"
             AutomationProperties.LiveSetting="Assertive">
    <Grid Background="{DynamicResource ScrimBrush}">
        <Border x:Name="ApprovalSheet"
                Width="640"
                MaxWidth="760"
                MaxHeight="620"
                Margin="24"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SurfaceRaisedBrush}"
                BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="12"
                KeyboardNavigation.TabNavigation="Cycle"
                KeyboardNavigation.ControlTabNavigation="Cycle"
                KeyboardNavigation.DirectionalNavigation="Contained">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Approval required"
                                   Style="{StaticResource TitleText}" />
                        <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Kind}"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="{DynamicResource WarningSubtleBrush}"
                            BorderBrush="{DynamicResource WarningBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="9,4"
                            VerticalAlignment="Top">
                        <TextBlock Text="Review carefully"
                                   Foreground="{DynamicResource WarningBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,0,20"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Reason}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="21"
                                   Margin="0,0,0,14" />
                        <TextBlock Text="Requested action"
                                   Style="{StaticResource SectionLabel}" />
                        <Border Padding="14"
                                Background="{DynamicResource SurfaceSunkenBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Detail}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       LineHeight="18"
                                       TextWrapping="Wrap"
                                       AutomationProperties.Name="Approval command or path detail" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding ApprovalQueue.ActivePrompt.PermissionOptions}"
                                      Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsGranted, Mode=TwoWay}"
                                              Margin="0,4"
                                              AutomationProperties.Name="{Binding Name}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding ApprovalQueue.ActivePrompt.Context}"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <Border Margin="0,12,0,0"
                                Padding="10"
                                Background="{DynamicResource DangerSubtleBrush}"
                                BorderBrush="{DynamicResource DangerBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{Binding ApprovalQueue.HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ApprovalQueue.ErrorMessage}"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Text="{Binding ApprovalQueue.PendingCount, StringFormat={}{0} pending approval request(s)}"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="11" />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CancelButton"
                            Content="Cancel request"
                            Command="{Binding ApprovalQueue.CancelCommand}"
                            Style="{StaticResource SubtleButton}"
                            HorizontalAlignment="Left"
                            IsDefault="False"
                            AutomationProperties.Name="Cancel approval request" />
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                        <Button Content="Decline"
                                Command="{Binding ApprovalQueue.DeclineCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="0,0,8,0"
                                IsDefault="False" />
                        <Button Content="Allow for session"
                                Command="{Binding ApprovalQueue.AllowSessionCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0"
                                IsDefault="False" />
                        <Button Content="Allow once"
                                Command="{Binding ApprovalQueue.AllowOnceCommand}"
                                Style="{StaticResource PrimaryButton}"
                                IsDefault="False" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
