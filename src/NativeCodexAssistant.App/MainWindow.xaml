<Window x:Class="NativeCodexAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Native Codex Assistant"
        MinHeight="680"
        MinWidth="1100"
        Height="760"
        Width="1240">
    <Grid Background="{StaticResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Native Codex Assistant" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedProjectPath, TargetNullValue=Select a project to begin}" Foreground="{StaticResource MutedInkBrush}" FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh" Command="{Binding RefreshDiagnosticsCommand}" Margin="0,0,8,0" />
                    <Button Content="Sign in" Command="{Binding SignInChatGptCommand}" Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource RailBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Projects" Style="{StaticResource SectionLabel}" />
                    <Button Grid.Row="1" Content="Add project" Command="{Binding BrowseProjectCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,16" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding RecentProjects}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Path}"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource LineBrush}"
                                        Margin="0,0,0,8"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Path}" Foreground="{StaticResource MutedInkBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource CopperBrush}" CornerRadius="3" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding SelectedProjectName}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedInkBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="22" Margin="0,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Thread surface" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="No active thread" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedProjectPath, TargetNullValue=Project workspace is empty}" Foreground="{StaticResource MutedInkBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,24,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Workspace" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedProjectName}" FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Codex" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding CodexSummary}" FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sign-in" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding AuthSummary}" FontWeight="SemiBold" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedInkBrush}" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <TextBlock Text="Diagnostics" Style="{StaticResource SectionLabel}" />

                        <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Codex" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CodexSummary}" Foreground="{StaticResource MutedInkBrush}" Margin="0,4,0,10" />
                                <TextBlock Text="{Binding CodexExecutablePath}" Style="{StaticResource ValueText}" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Sign-in" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AuthSummary}" Foreground="{StaticResource MutedInkBrush}" Margin="0,4,0,8" />
                                <TextBlock Text="{Binding AuthDetail}" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="ChatGPT" Command="{Binding SignInChatGptCommand}" Margin="0,0,8,0" />
                                    <Button Content="Device code" Command="{Binding SignInDeviceCodeCommand}" Margin="0,0,8,0" />
                                    <Button Content="Sign out" Command="{Binding SignOutCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Codex home" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CodexHome}" Style="{StaticResource ValueText}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Runtime" Style="{StaticResource SectionLabel}" Margin="0,4,0,8" />
                        <ItemsControl ItemsSource="{Binding Diagnostics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="0,0,0,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource InkBrush}">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" VerticalAlignment="Center" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding SettingsPath}" Foreground="#C9D4CE" VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</Window>
