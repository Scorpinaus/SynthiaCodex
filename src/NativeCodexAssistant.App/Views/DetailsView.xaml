<UserControl x:Class="NativeCodexAssistant.App.Views.DetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Settings">
    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource LineBrush}"
            BorderThickness="1,0,0,0">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Appearance, account, and diagnostics"
                               Foreground="{DynamicResource MutedInkBrush}"
                               FontSize="11"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Close"
                        Command="{Binding ToggleDetailsPaneCommand}"
                        Style="{StaticResource CompactButton}"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Appearance" FontWeight="SemiBold"/>
                            <TextBlock Text="Theme"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       Margin="0,6,0,4"/>
                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Execution policy" FontWeight="SemiBold"/>
                            <TextBlock Text="Filesystem sandbox"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       Margin="0,6,0,4"/>
                            <ComboBox ItemsSource="{Binding ExecutionPolicy.SandboxModeOptions}"
                                      SelectedItem="{Binding ExecutionPolicy.SelectedSandboxMode, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Server-request approvals"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding ExecutionPolicy.ApprovalPolicyOptions}"
                                      SelectedItem="{Binding ExecutionPolicy.SelectedApprovalPolicy, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Stretch"/>
                            <TextBlock Text="{Binding ExecutionPolicy.EffectiveSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ExecutionPolicy.ManagedSummary}"
                                       Margin="0,5,0,0"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ExecutionPolicy.ConfigurationWarning}"
                                       Margin="0,5,0,0"
                                       Foreground="{DynamicResource DangerBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Account" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Account.DisplayName}"
                                       FontWeight="SemiBold"
                                       Margin="0,6,0,2"/>
                            <TextBlock Text="{Binding Account.IdentityDetail}"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding DiagnosticsViewModel.AuthDetail}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="ChatGPT"
                                        Command="{Binding DiagnosticsViewModel.SignInChatGptCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,6"/>
                                <Button Content="Device code"
                                        Command="{Binding DiagnosticsViewModel.SignInDeviceCodeCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,6"/>
                                <Button Content="Sign out"
                                        Command="{Binding DiagnosticsViewModel.SignOutCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,0,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Codex runtime" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DiagnosticsViewModel.CodexSummary}"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,8"/>
                            <TextBlock Text="{Binding DiagnosticsViewModel.CodexExecutablePath}"
                                       Style="{StaticResource ValueText}"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Refresh"
                                        Command="{Binding DiagnosticsViewModel.RefreshCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,0"/>
                                <Button Content="Run doctor"
                                        Command="{Binding DiagnosticsViewModel.RunDoctorCommand}"
                                        Style="{StaticResource CompactButton}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Expander Header="Advanced diagnostics" IsExpanded="False" Margin="0,0,0,8">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="{Binding DiagnosticsViewModel.CodexHome, StringFormat=Codex home: {0}}"
                                       Style="{StaticResource ValueText}"
                                       Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding DiagnosticsViewModel.Lines}"
                                     MaxHeight="360"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.CanContentScroll="True">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="0,0,0,7"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Raw protocol events" IsExpanded="False">
                        <ListBox ItemsSource="{Binding TaskWorkspace.RawEvents}"
                                 MaxHeight="360"
                                 Margin="0,8,0,0"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="4,5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
