<UserControl x:Class="SynthiaCode.App.Views.DetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Settings">
    <Border Background="{DynamicResource InspectorBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1,0,0,0">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Instructions, appearance, account, and diagnostics"
                               Foreground="{DynamicResource MutedInkBrush}"
                               FontSize="11"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Close"
                        Command="{Binding ToggleDetailsPaneCommand}"
                        Style="{StaticResource CompactButton}"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="General" FontWeight="SemiBold"/>
                            <TextBlock Text="Follow-up behavior"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       Margin="0,6,0,4"/>
                            <ComboBox x:Name="FollowUpBehaviorSelector"
                                      ItemsSource="{Binding TaskWorkspace.FollowUpBehaviorOptions}"
                                      SelectedItem="{Binding TaskWorkspace.FollowUpBehavior, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.Name="Follow-up behavior"/>
                            <TextBlock Text="Queue waits for the next turn; Steer changes the current run. Ctrl+Shift+Enter uses the other behavior once."
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Codex instructions" FontWeight="SemiBold"/>
                            <TextBlock Text="Defaults are captured when a new chat is created. Existing chats keep their original instructions."
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,8"/>
                            <CheckBox Content="Use custom developer instructions"
                                      IsChecked="{Binding DeveloperInstructionsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox x:Name="DeveloperInstructionsEditor"
                                     Text="{Binding DeveloperInstructions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding DeveloperInstructionsEnabled}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="96"
                                     MaxHeight="220"
                                     Padding="8"
                                     Margin="0,6,0,0"
                                     AutomationProperties.Name="Developer instructions"
                                     ToolTip="Additional developer-role guidance applied to future Codex chats."/>

                            <Expander Header="Advanced: Base instructions override"
                                      IsExpanded="False"
                                      Margin="0,10,0,0">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="This replaces the selected model's built-in Codex base instructions. Leave it off to use the model default from the Codex runtime."
                                               Foreground="{DynamicResource WarningBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>
                                    <CheckBox Content="Replace model base instructions"
                                              IsChecked="{Binding BaseInstructionsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox x:Name="BaseInstructionsEditor"
                                             Text="{Binding BaseInstructions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding BaseInstructionsEnabled}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="96"
                                             MaxHeight="220"
                                             Padding="8"
                                             Margin="0,6,0,0"
                                             AutomationProperties.Name="Base instructions override"
                                             ToolTip="Advanced replacement for the model's built-in Codex base instructions."/>
                                </StackPanel>
                            </Expander>

                            <TextBlock Text="{Binding InstructionSettingsValidationMessage}"
                                       Foreground="{DynamicResource WarningBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="Instructions are stored as plain text in SynthiaCode settings. Do not include passwords, API keys, or other secrets."
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button x:Name="SaveInstructionSettingsButton"
                                        Content="Save instructions"
                                        Command="{Binding SaveInstructionSettingsCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,0"/>
                                <Button x:Name="ResetInstructionSettingsButton"
                                        Content="Reset"
                                        Command="{Binding ResetInstructionSettingsCommand}"
                                        Style="{StaticResource CompactButton}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Appearance" FontWeight="SemiBold"/>
                            <TextBlock Text="Theme"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       FontSize="11"
                                       Margin="0,6,0,4"/>
                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Account" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Account.DisplayName}"
                                       FontWeight="SemiBold"
                                       Margin="0,6,0,2"/>
                            <TextBlock Text="{Binding Account.IdentityDetail}"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding DiagnosticsViewModel.AuthDetail}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="ChatGPT"
                                        Command="{Binding DiagnosticsViewModel.SignInChatGptCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,6"/>
                                <Button Content="Device code"
                                        Command="{Binding DiagnosticsViewModel.SignInDeviceCodeCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,6"/>
                                <Button Content="Sign out"
                                        Command="{Binding DiagnosticsViewModel.SignOutCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,0,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Codex runtime" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DiagnosticsViewModel.CodexSummary}"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,8"/>
                            <TextBlock Text="{Binding DiagnosticsViewModel.CodexExecutablePath}"
                                       Style="{StaticResource ValueText}"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Refresh"
                                        Command="{Binding DiagnosticsViewModel.RefreshCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,0"/>
                                <Button Content="Run doctor"
                                        Command="{Binding DiagnosticsViewModel.RunDoctorCommand}"
                                        Style="{StaticResource CompactButton}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="48"
                                    Height="48"
                                    Padding="3"
                                    Background="{DynamicResource SurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Image x:Name="AboutLogoImage"
                                       Source="/SynthiaCode.App;component/Assets/Branding/SynthiaCodeLogo.png"
                                       Stretch="Uniform"
                                       IsHitTestVisible="False"
                                       AutomationProperties.Name="SynthiaCode logo"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="About SynthiaCode" FontWeight="SemiBold"/>
                                <TextBlock Text="SynthiaCode is an independent application and is not affiliated with or endorsed by OpenAI."
                                           Foreground="{DynamicResource MutedInkBrush}"
                                           FontSize="11"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Expander Header="Advanced diagnostics" IsExpanded="False" Margin="0,0,0,8">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="{Binding DiagnosticsViewModel.CodexHome, StringFormat=Codex home: {0}}"
                                       Style="{StaticResource ValueText}"
                                       Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding DiagnosticsViewModel.Lines}"
                                     MaxHeight="360"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.CanContentScroll="True">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="0,0,0,7"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Raw protocol events" IsExpanded="False">
                        <ListBox ItemsSource="{Binding TaskWorkspace.RawEvents}"
                                 MaxHeight="360"
                                 Margin="0,8,0,0"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Margin="4,5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
